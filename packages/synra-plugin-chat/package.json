{
  "name": "@synra-plugin/chat",
  "version": "0.1.0",
  "description": "Built-in chat UI plugin for Synra.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pages/home": "./pages/home/index.vue",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./pages/home": "./dist/pages/home/index.mjs",
      "./package.json": "./package.json",
      "./style.css": "./dist/style.css"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@synra/plugin-sdk": "workspace:*",
    "vue": "catalog:vue"
  },
  "devDependencies": {
    "@iconify-json/eos-icons": "^1.2.4",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:types",
    "@unocss/preset-icons": "catalog:unocss",
    "@unocss/preset-wind3": "catalog:unocss",
    "bumpp": "catalog:release",
    "typescript": "catalog:types",
    "unocss": "catalog:unocss",
    "vite-plus": "catalog:vite"
  },
  "synra": {
    "title": "Chat",
    "builtin": true,
    "icon": "material-symbols:chat-bubble-outline"
  }
}
