{
  "name": "@synra/hooks",
  "version": "0.0.0",
  "description": "Unified runtime-driven hooks for Synra.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@synra/capacitor-device-connection": "workspace:*",
    "@synra/capacitor-lan-discovery": "workspace:*",
    "@synra/capacitor-preferences": "workspace:*",
    "@synra/protocol": "workspace:*",
    "vue": "catalog:vue"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "bumpp": "catalog:release",
    "typescript": "catalog:types",
    "vite-plus": "catalog:vite"
  }
}
