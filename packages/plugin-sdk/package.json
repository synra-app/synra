{
  "name": "@synra/plugin-sdk",
  "version": "0.0.0",
  "description": "Plugin contracts for Synra cross-device runtime.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./vite": "./src/vite.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./hooks": "./dist/hooks/index.mjs",
      "./vite": "./dist/vite.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@synra/protocol": "workspace:*",
    "@unocss/vite": "catalog:unocss",
    "@vitejs/plugin-vue": "catalog:vite",
    "tinyglobby": "catalog:build",
    "unplugin-auto-import": "catalog:vite",
    "unplugin-vue": "catalog:vite",
    "unplugin-vue-components": "catalog:vite",
    "vite-plus": "catalog:vite",
    "vue": "catalog:vue"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "bumpp": "catalog:release",
    "typescript": "catalog:types"
  }
}
