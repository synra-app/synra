{
  "name": "vite-plugin-synra-electron",
  "version": "0.0.0",
  "description": "Synra development plugin for Electron + frontend hot workflow.",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
